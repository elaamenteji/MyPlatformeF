# 1. El "Bab" elli Node.js bech yesma3 mennou el requests (Backend)
PORT=5000

# 2. Ma3loumet el Database (PostgreSQL)
DB_HOST=localhost       # El base mawjouda fi nafs el PC (mouch fil cloud)
DB_PORT=5432            # El port el 3adi mta3 PostgreSQL
DB_USER=postgres        # Esm el "Admin" mta3 el base
DB_PASSWORD=123POSTGRES # Kelmet el sirr bsh n7ellou el khizna
DB_NAME=constructpro_db # Esm el "Sando9" (Database) elli fih el tables

# 3. El "Secrets" mta3 el Sécurité (JWT - Login)
# Hedha el "Mofte7" elli n'shifriw bih el Badge (Token) mta3 el user
JWT_SECRET=myplatforme_secret_key_2026
JWT_EXPIRES_IN=1h       # El Badge youfa ba3d sa3a (bsh ma yessra9ha 7ad)

# Hedha mofte7 e5er bsh n3tiw Badge jdid (Refresh) min ghir ma el user i3awed l'password
JWT_REFRESH_SECRET=myplatforme_refresh_secret_2026
JWT_REFRESH_EXPIRES_IN=7d # El badge hedha youfa ba3d 7 ayyam

# 4. El Adresse mta3 el Frontend (React/Vue)
# Node.js ma yjaweb ken el requests elli jyin mel blassa hedhi (CORS)
CLIENT_URL=http://localhost:3000